<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HydraulicJournalApp.DevelopersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Разработчики">

    <Grid RowDefinitions="Auto,Auto,*" Padding="12">
        <Label Text="Разработчики"
               FontSize="24"
               FontAttributes="Bold" />

        <VerticalStackLayout Grid.Row="1" Spacing="8" Margin="0,12,0,12">
            <Entry x:Name="DeveloperEntry" Placeholder="ФИО разработчика" />
            <Button Text="Добавить разработчика" Clicked="OnAddDeveloper" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="2" x:Name="DevelopersList" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="0,0,0,8">
                        <Label Text="{Binding FullName}" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>