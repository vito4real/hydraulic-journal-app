<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HydraulicJournalApp.JournalEntryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Новая запись">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="10">
            <Label Text="Новая запись журнала"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Frame Padding="6"
                   BorderColor="#007ACC"
                   BackgroundColor="#F5FAFF"
                   CornerRadius="8"
                   HasShadow="False">
                <Entry x:Name="DesignationEntry"
                       Placeholder="Обозначение изделия"
                       TextChanged="OnDesignationTextChanged"
                       Focused="OnDesignationFocused"
                       Unfocused="OnDesignationUnfocused"
                       BackgroundColor="Transparent" />
            </Frame>

            <Border x:Name="DesignationResultsBorder"
                    Stroke="#D0D7DE"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    IsVisible="False"
                    StrokeShape="RoundRectangle 8">
                <CollectionView x:Name="DesignationResultsList"
                                SelectionMode="Single"
                                SelectionChanged="OnDesignationSelected"
                                MaximumHeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Designation}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Name}"
                                           FontSize="12"
                                           TextColor="Gray" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Frame Padding="6"
                   BorderColor="#007ACC"
                   BackgroundColor="#F5FAFF"
                   CornerRadius="8"
                   HasShadow="False">
                <Entry x:Name="ProductNameEntry"
                       Placeholder="Наименование изделия"
                       TextChanged="OnProductNameTextChanged"
                       Focused="OnProductNameFocused"
                       BackgroundColor="Transparent" />
            </Frame>

            <Border x:Name="ProductNameResultsBorder"
                    Stroke="#D0D7DE"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    IsVisible="False"
                    StrokeShape="RoundRectangle 8">
                <CollectionView x:Name="ProductNameResultsList"
                                SelectionMode="Single"
                                SelectionChanged="OnProductNameSelected"
                                MaximumHeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Designation}"
                                           FontSize="12"
                                           TextColor="Gray" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Label Text="Клиент" />

            <Frame Padding="6"
                   BorderColor="#007ACC"
                   BackgroundColor="#F5FAFF"
                   CornerRadius="8"
                   HasShadow="False">
                <Entry x:Name="CustomerSearchEntry"
                       Placeholder="Начните вводить клиента"
                       TextChanged="OnCustomerSearchTextChanged"
                       Focused="OnCustomerSearchFocused"
                       BackgroundColor="Transparent" />
            </Frame>

            <Border x:Name="CustomerResultsBorder"
                    Stroke="#D0D7DE"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    IsVisible="False"
                    StrokeShape="RoundRectangle 8">
                <CollectionView x:Name="CustomerResultsList"
                                SelectionMode="Single"
                                SelectionChanged="OnCustomerSelected"
                                MaximumHeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10">
                                <Label Text="{Binding Name}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Label Text="Разработчик" />

            <Frame Padding="6"
                   BorderColor="#007ACC"
                   BackgroundColor="#F5FAFF"
                   CornerRadius="8"
                   HasShadow="False">
                <Entry x:Name="DeveloperSearchEntry"
                       Placeholder="Начните вводить разработчика"
                       TextChanged="OnDeveloperSearchTextChanged"
                       Focused="OnDeveloperSearchFocused"
                       BackgroundColor="Transparent" />
            </Frame>

            <Border x:Name="DeveloperResultsBorder"
                    Stroke="#D0D7DE"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    IsVisible="False"
                    StrokeShape="RoundRectangle 8">
                <CollectionView x:Name="DeveloperResultsList"
                                SelectionMode="Single"
                                SelectionChanged="OnDeveloperSelected"
                                MaximumHeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10">
                                <Label Text="{Binding FullName}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <DatePicker x:Name="IssueDatePicker" />

            <Picker x:Name="KitTypePicker" Title="Тип комплекта">
                <Picker.Items>
                    <x:String>Опытный</x:String>
                    <x:String>Контрольный</x:String>
                </Picker.Items>
            </Picker>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Сохранить запись"
                        Clicked="OnAddJournalEntry"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Сброс"
                        Clicked="OnResetClicked"
                        HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>