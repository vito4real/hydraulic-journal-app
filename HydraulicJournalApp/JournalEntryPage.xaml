<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HydraulicJournalApp.JournalEntryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Новая запись">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="10">
            <Label Text="Новая запись журнала"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Entry x:Name="DesignationEntry" Placeholder="Обозначение изделия" Unfocused="OnDesignationUnfocused" />
            <Entry x:Name="ProductNameEntry" Placeholder="Наименование изделия" />

            <Picker x:Name="CustomerPicker" Title="Клиент" />
            <Picker x:Name="DeveloperPicker" Title="Разработчик" />

            <DatePicker x:Name="IssueDatePicker" />

            <Picker x:Name="KitTypePicker" Title="Тип комплекта">
                <Picker.Items>
                    <x:String>Опытный</x:String>
                    <x:String>Контрольный</x:String>
                </Picker.Items>
            </Picker>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Сохранить запись"
                        Clicked="OnAddJournalEntry"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Сброс"
                        Clicked="OnResetClicked"
                        HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>