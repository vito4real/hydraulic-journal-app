<ContentPage
    x:Class="HydraulicJournalApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Журнал">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="10">

        <Label Grid.Row="0"
               Text="Журнал выдачи чертежей"
               FontSize="24"
               FontAttributes="Bold"
               Margin="0,0,0,10" />

        <Grid Grid.Row="1"
            ColumnDefinitions="*,*,*,Auto"
            ColumnSpacing="10"
            Margin="0,0,0,10">

            <!-- Поиск по обозначению -->
            <Frame Grid.Column="0"
                Padding="6"
                BorderColor="#007ACC"
                BackgroundColor="#F5FAFF"
                CornerRadius="8"
                HasShadow="False">
                <Entry x:Name="DesignationSearchEntry"
                    Placeholder="Поиск по обозначению / наименованию"
                    TextChanged="OnSearchTextChanged"
                    BackgroundColor="Transparent" />
            </Frame>

            <!-- Поиск по разработчику -->
            <Frame Grid.Column="1"
                Padding="6"
                BorderColor="#007ACC"
                BackgroundColor="#F5FAFF"
                CornerRadius="8"
                HasShadow="False">
                <Entry x:Name="DeveloperSearchEntry"
                    Placeholder="Поиск по разработчику"
                    TextChanged="OnSearchTextChanged"
                    BackgroundColor="Transparent" />
            </Frame>

            <!-- Поиск по заказчику -->
            <Frame Grid.Column="2"
                Padding="6"
                BorderColor="#007ACC"
                BackgroundColor="#F5FAFF"
                CornerRadius="8"
                HasShadow="False">
                <Entry x:Name="CustomerSearchEntry"
                    Placeholder="Поиск по заказчику"
                    TextChanged="OnSearchTextChanged"
                    BackgroundColor="Transparent" />
            </Frame>

            <!-- Кнопка -->
            <Button Grid.Column="3"
                    Text="Сброс"
                    Clicked="OnResetFiltersClicked" />
        </Grid>

        <Grid Grid.Row="2"
            ColumnDefinitions="1.8*,2.2*,1.6*,1.2*,1.4*,1.8*"
            Padding="8"
            BackgroundColor="#D9D9D9"
            ColumnSpacing="8">
            <Label Grid.Column="0" Text="Обозначение изделия" FontAttributes="Bold" />
            <Label Grid.Column="1" Text="Наименование изделия" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="Разработчик" FontAttributes="Bold" />
            <Label Grid.Column="3" Text="Дата выдачи" FontAttributes="Bold" />
            <Label Grid.Column="4" Text="Вид комплекта" FontAttributes="Bold" />
            <Label Grid.Column="5" Text="Заказчик" FontAttributes="Bold" />
        </Grid>

        <CollectionView Grid.Row="3"
                        x:Name="JournalList"
                        Margin="0,4,0,0"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="1.8*,2.2*,1.6*,1.2*,1.4*,1.8*"
                        Padding="8"
                        ColumnSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Column="0"
                            Text="{Binding Designation}"
                            LineBreakMode="TailTruncation" />

                        <Label Grid.Column="1"
                            Text="{Binding ProductName}"
                            LineBreakMode="TailTruncation" />

                        <Label Grid.Column="2"
                            Text="{Binding DeveloperName}"
                            LineBreakMode="TailTruncation" />

                        <Label Grid.Column="3"
                            Text="{Binding IssueDateDisplay}" />

                        <Label Grid.Column="4"
                            Text="{Binding KitTypeDisplay}" />

                        <Label Grid.Column="5"
                            Text="{Binding CustomerName}"
                            LineBreakMode="TailTruncation" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>