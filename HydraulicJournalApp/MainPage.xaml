<ContentPage
    x:Class="HydraulicJournalApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Журнал">

    <Grid RowDefinitions="Auto,Auto,*" Padding="10">

        <Label Grid.Row="0"
               Text="Журнал выдачи чертежей"
               FontSize="24"
               FontAttributes="Bold"
               Margin="0,0,0,10" />

        <Grid Grid.Row="1"
              ColumnDefinitions="2.2*,1.6*,1.2*,1.4*,1.8*"
              Padding="8"
              BackgroundColor="#D9D9D9"
              ColumnSpacing="8">
            <Label Grid.Column="0" Text="Обозначение изделия" FontAttributes="Bold" />
            <Label Grid.Column="1" Text="Разработчик" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="Дата выдачи" FontAttributes="Bold" />
            <Label Grid.Column="3" Text="Вид комплекта" FontAttributes="Bold" />
            <Label Grid.Column="4" Text="Заказчик" FontAttributes="Bold" />
        </Grid>

        <CollectionView Grid.Row="2"
                        x:Name="JournalList"
                        Margin="0,4,0,0"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="2.2*,1.6*,1.2*,1.4*,1.8*"
                          Padding="8"
                          ColumnSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Column="0"
                               Text="{Binding Designation}"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Column="1"
                               Text="{Binding DeveloperName}"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Column="2"
                               Text="{Binding IssueDateDisplay}" />

                        <Label Grid.Column="3"
                               Text="{Binding KitTypeDisplay}" />

                        <Label Grid.Column="4"
                               Text="{Binding CustomerName}"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>