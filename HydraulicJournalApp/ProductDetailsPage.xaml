<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HydraulicJournalApp.ProductDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Изделие">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="14">

            <Label x:Name="DesignationLabel"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label x:Name="ProductNamesLabel"
                   FontSize="16" />

            <Label Text="Заказчики данного изделия"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,10,0,0" />

            <Grid ColumnDefinitions="2*,3*"
                  Padding="8"
                  BackgroundColor="#D9D9D9"
                  ColumnSpacing="8">
                <Label Grid.Column="0" Text="Заказчик" FontAttributes="Bold" />
                <Label Grid.Column="1" Text="Наименование" FontAttributes="Bold" />
            </Grid>

            <CollectionView x:Name="CustomersList"
                            SelectionMode="None"
                            MaximumHeightRequest="220">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="2*,3*"
                              Padding="8"
                              ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="{Binding CustomerName}"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Column="1"
                                   Text="{Binding ProductName}"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="История выдачи"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,10,0,0" />

            <Grid ColumnDefinitions="2*,1.5*,1.5*,1.5*,1.5*"
                  Padding="8"
                  BackgroundColor="#D9D9D9"
                  ColumnSpacing="8">
                <Label Grid.Column="0" Text="Заказчик" FontAttributes="Bold" />
                <Label Grid.Column="1" Text="Разработчик" FontAttributes="Bold" />
                <Label Grid.Column="2" Text="Дата ТЗ" FontAttributes="Bold" />
                <Label Grid.Column="3" Text="Дата КД" FontAttributes="Bold" />
                <Label Grid.Column="4" Text="Наименование" FontAttributes="Bold" />
            </Grid>

            <CollectionView x:Name="JournalEntriesList"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="2*,1.5*,1.5*,1.5*,1.5*"
                              Padding="8"
                              ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="{Binding CustomerName}"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Column="1"
                                   Text="{Binding DeveloperName}"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Column="2"
                                   Text="{Binding IssueDateDisplay}" />

                            <Label Grid.Column="3"
                                   Text="{Binding DocumentationIssuedDateDisplay}" />

                            <Label Grid.Column="4"
                                   Text="{Binding ProductName}"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>